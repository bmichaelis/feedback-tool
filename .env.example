# GitHub Personal Access Token with "repo" scope
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# API keys mapped to GitHub repos — format: key:org/repo (comma-separated, one per host app)
# Generate a key with: openssl rand -hex 16
WIDGET_API_KEYS=key_abc123:org/repo-one,key_def456:org/repo-two

# Provided automatically when you run: vercel integrations add blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here
